## VizNow marketing site public env template
## Copy to .env.local for local overrides. Configure production values in Vercel.

# Optional deployment label shown only to client-side code.
NEXT_PUBLIC_APP_ENV=dev

# Canonical public site origin used by metadata.
NEXT_PUBLIC_SITE_URL=https://viznow.ai

# Optional static asset origin. Leave empty to use same-origin assets from /public.
NEXT_PUBLIC_STATIC_BASE_URL=

# Optional public analytics token.
NEXT_PUBLIC_MIXPANEL_TOKEN=
